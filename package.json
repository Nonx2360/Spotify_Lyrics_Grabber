{
  "name": "spotify-lyrics-grabber",
  "version": "1.0.0",
  "description": "Real-time Spotify lyrics display with terminal UI",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "cd src/web && npm run dev",
    "cli": "tsx src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
